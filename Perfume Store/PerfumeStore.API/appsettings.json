{
    "ConnectionStrings": {
        "DefaultConnection": "Server=.;Database=MyAppDb;Trusted_Connection=True;TrustServerCertificate=True",
        "Redis": "localhost:6379"
    },
    "JwtSettings": {
        "SecretKey": "YourSuperSecretKeyAtLeast32CharactersLong!",
        "Issuer": "MyApp",
